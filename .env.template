# DEFCON Monitor — Environment Variables Template
# Copy this file to .env and fill in your values.
# Load with: export $(cat .env | xargs)

# ── Location ────────────────────────────────────────────────────────────────
# Your NWS weather zone — find at https://www.weather.gov/publish/
NWS_ZONE=OHZ061

# ── ClawdWatch (optional) ─────────────────────────────────────────────────
# URL of your local ClawdWatch OSINT agent (if running)
CLAWDWATCH_URL=http://localhost:3444

# ── Telegram Alerts (optional) ──────────────────────────────────────────────
# Get bot token from @BotFather, chat_id from @userinfobot
DEFCON_TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE
DEFCON_TELEGRAM_CHAT_ID=YOUR_CHAT_ID_HERE
DEFCON_TELEGRAM_TOPIC_ID=

# ── Email Alerts via SMTP (optional) ───────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_TO=recipient@example.com

# ── npm Audit (optional) ────────────────────────────────────────────────────
# Directory containing package.json to scan
NODE_PROJECT_DIR=/path/to/your/project

# ── Paths (usually fine to leave default) ──────────────────────────────────
DEFCON_STATE_DIR=
DEFCON_LOG_DIR=
